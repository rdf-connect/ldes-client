{
  "name": "ldes-client",
  "description": "This package provides common tooling to work with LDESes.",
  "version": "0.3.2",
  "main": "dist/lib/client.js",
  "exports": {
    "import": "./dist/lib/client.js",
    "require": "./dist/lib/client.cjs"
  },
  "type": "module",
  "bin": {
    "ldes-client": "dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias && rollup -c",
    "test": "vitest run --coverage --coverage.include lib --coverage.exclude dist",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*",
    "shapes/**/*",
    "dist/bin/**/*",
    "processor.ttl"
  ],
  "directories": {
    "lib": "lib",
    "bin": "bin",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rdf-connect/ldes-client"
  },
  "author": "Arthur Vercruysse",
  "license": "MIT",
  "dependencies": {
    "@treecg/types": "^0.4.6",
    "commander": "^14.0.3",
    "extract-cbd-shape": "0.1.15",
    "heap-js": "^2.7.1",
    "level": "^10.0.0",
    "n3": "^2.0.3",
    "rdf-data-factory": "^2.0.2",
    "rdf-dereference": "^5.0.0",
    "rdf-lens": "^1.3.7",
    "rdf-stores": "^2.2.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "@grpc/grpc-js": "^1.14.3",
    "@rdfc/js-runner": "^3.1.0",
    "@rdfc/proto": "^0.1.3",
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "benchmark": "^2.1.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "fastify": "^5.8.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "browser": {
    "fs": false,
    "fs/promises": false,
    "path": false,
    "os": false
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.28.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  }
}
